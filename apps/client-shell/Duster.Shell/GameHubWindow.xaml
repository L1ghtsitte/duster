<Window x:Class="Duster.Shell.GameHubWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Hub" Height="500" Width="640" Background="#0f1419">
  <Grid Margin="16">
    <StackPanel>
      <TextBlock Text="GAME HUB" FontSize="24" Foreground="#5b8def" FontWeight="Bold"/>
      <TextBlock x:Name="StatusText" Foreground="#8b9cb3" Margin="0,8,0,12"/>
      <ListBox x:Name="GamesList" Height="360" Background="#1a2332" Foreground="#fff" BorderBrush="#2d3a4f"/>
      <Button Content="Играть" Height="44" Margin="0,12,0,0" Click="PlayClick" Background="#5b8def" Foreground="White" BorderThickness="0"/>
    </StackPanel>
  </Grid>
</Window>
