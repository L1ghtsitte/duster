# Duster Environment Configuration
# Скопируйте в packages/server/.env перед запуском

# Сервер
DUSTER_HOST=0.0.0.0
DUSTER_PORT=3847
DUSTER_JWT_SECRET=change-me-to-long-random-string-min-32-chars
DUSTER_PUBLIC_URL=https://your-club.example
DUSTER_DEFAULT_CLUB_SLUG=default

# PostgreSQL
DATABASE_URL=postgresql://duster:duster@localhost:5432/duster

# Redis
REDIS_URL=redis://localhost:6379

# Админ по умолчанию
DUSTER_DEFAULT_ADMIN_LOGIN=admin
DUSTER_DEFAULT_ADMIN_PASSWORD=admin123

# Telegram (опционально)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=/api/telegram/webhook
TELEGRAM_WEBHOOK_PATH=/api/telegram/webhook